{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "rootDir": "./Sources/codigo-editor/Web",
    "declaration": false,
    "sourceMap": false,
    "noEmit": true
  },
  "include": [
    "Sources/codigo-editor/Web/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
